PORT=4000
SQLITE_DB_PATH=apps/api/data/miclub.sqlite
VITE_API_URL=

# PostgreSQL como fuente oficial
POSTGRES_ENABLED=true
DATA_SOURCE=postgres
CRM_SOURCE=postgres

# Opción A: conexión por variables PG*
# Usar estos valores si PostgreSQL está local en el mismo servidor.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=miclub_gestion
PGUSER=miclub_app
PGPASSWORD=mi_contraseña_segura
PGSSL=false

# Google Sheets retirado / apagado
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=mi_id_de_hoja_de_calculo
GOOGLE_SERVICE_ACCOUNT_EMAIL=miclub-sheets-reader@miclub-crm.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=mi_clave_privada_segura
GOOGLE_SHEETS_FITNESS_RANGE=FITNESS!AB20:AY800
GOOGLE_SHEETS_SALON_RANGE=SALON!AB34:AY800
GOOGLE_SHEETS_AULA_RANGE=AULA!AB34:AY800

# Seguridad / login
AUTH_ENABLED=true
AUTH_USER=administracion@miclub.com
AUTH_PASSWORD=mi_password_seguro
SESSION_SECRET=mi_secreto_de_sesion_seguro
PUBLIC_APP_URL=https://gestion.meclub.com.ar

# Endpoints operativos sensibles apagados en producción
DEBUG_ENDPOINTS_ENABLED=false
IMPORT_ENDPOINTS_ENABLED=false