PORT=4000
SQLITE_DB_PATH=apps/api/data/miclub.sqlite
# Frontend API base URL. Leave empty or omit in production behind Cloudflare Tunnel
# so the web app uses same-origin relative routes like /auth/login and /summary.
# For split local dev (Vite on 5173 + API on 4000), set http://localhost:4000.
VITE_API_URL=
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_FITNESS_RANGE=FITNESS!AB20:AY800
GOOGLE_SHEETS_SALON_RANGE=SALON!AB34:AY800
GOOGLE_SHEETS_AULA_RANGE=AULA!AB34:AY800
AUTH_ENABLED=false
AUTH_USER=
AUTH_PASSWORD=
SESSION_SECRET=
PUBLIC_APP_URL=
