PORT=4000
SQLITE_DB_PATH=apps/api/data/miclub.sqlite
VITE_API_URL=

# PostgreSQL como fuente oficial
POSTGRES_ENABLED=true
DATA_SOURCE=postgres
CRM_SOURCE=postgres

# Opción A: conexión por variables PG*
# Usar estos valores si PostgreSQL está local en el mismo servidor.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=miclub_gestion
PGUSER=miclub_app
PGPASSWORD=mi_contraseña_segura
PGSSL=false

# Google Sheets retirado / apagado
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=mi_id_de_hoja_de_calculo
GOOGLE_SERVICE_ACCOUNT_EMAIL=miclub-sheets-reader@miclub-crm.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=mi_clave_privada_segura
# Rangos de inscriptos
GOOGLE_SHEETS_FITNESS_MEMBERS_HEADER_RANGE=FITNESS!AB19:BA19
GOOGLE_SHEETS_FITNESS_RANGE=FITNESS!AB20:BA1500
# Si Operaciones confirma Fitness hasta BB, usar estas alternativas:
# GOOGLE_SHEETS_FITNESS_MEMBERS_HEADER_RANGE=FITNESS!AB19:BB19
# GOOGLE_SHEETS_FITNESS_RANGE=FITNESS!AB20:BB1500
GOOGLE_SHEETS_SALON_MEMBERS_HEADER_RANGE=SALON!AB33:BB33
GOOGLE_SHEETS_SALON_RANGE=SALON!AB34:BB1500
GOOGLE_SHEETS_AULA_MEMBERS_HEADER_RANGE=AULA!AB33:BB33
GOOGLE_SHEETS_AULA_RANGE=AULA!AB34:BB1500

# Rangos de movimientos
GOOGLE_SHEETS_FITNESS_MOVEMENTS_HEADER_RANGE=FITNESS!B19:Y19
GOOGLE_SHEETS_FITNESS_MOVEMENTS_RANGE=FITNESS!B20:Y1500
GOOGLE_SHEETS_SALON_MOVEMENTS_HEADER_RANGE=SALON!B33:Y33
GOOGLE_SHEETS_SALON_MOVEMENTS_RANGE=SALON!B34:Y1500
GOOGLE_SHEETS_AULA_MOVEMENTS_HEADER_RANGE=AULA!B33:Y33
GOOGLE_SHEETS_AULA_MOVEMENTS_RANGE=AULA!B34:Y1500
GOOGLE_SHEETS_ADMIN_MOVEMENTS_HEADER_RANGE=ADMINISTRACIÓN!B12:AB12
GOOGLE_SHEETS_ADMIN_MOVEMENTS_RANGE=ADMINISTRACIÓN!B13:AB3000
# LOCAL 1 pendiente de confirmar fila de header antes de habilitarlo.
# GOOGLE_SHEETS_LOCAL_1_MOVEMENTS_HEADER_RANGE='LOCAL 1'!B<fila_header>:<columna_final><fila_header>
# GOOGLE_SHEETS_LOCAL_1_MOVEMENTS_RANGE='LOCAL 1'!B<primera_fila_datos>:<columna_final>3000

# Seguridad / login
AUTH_ENABLED=true
AUTH_USER=administracion@miclub.com
AUTH_PASSWORD=mi_password_seguro
SESSION_SECRET=mi_secreto_de_sesion_seguro
PUBLIC_APP_URL=https://gestion.meclub.com.ar

# Endpoints operativos sensibles apagados en producción
DEBUG_ENDPOINTS_ENABLED=false
IMPORT_ENDPOINTS_ENABLED=false