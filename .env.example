PORT=4000
SQLITE_DB_PATH=apps/api/data/miclub.sqlite

# PostgreSQL (disabled by default; legacy keeps Google Sheets/SQLite/mocks behavior)
# Set POSTGRES_ENABLED=true before using DATA_SOURCE=postgres or CRM_SOURCE=postgres in production.
POSTGRES_ENABLED=false
# legacy keeps the current Google Sheets/mocks operational data path; postgres uses PostgreSQL repositories.
DATA_SOURCE=legacy
# sqlite keeps CRM templates/history in the local SQLite file; postgres uses PostgreSQL CRM tables.
CRM_SOURCE=sqlite
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=miclub
PGUSER=miclub
PGPASSWORD=
PGSSL=false
# Frontend API base URL. Leave empty or omit in production behind Cloudflare Tunnel
# so the web app uses same-origin relative routes like /auth/login and /summary.
# For split local dev (Vite on 5173 + API on 4000), set http://localhost:4000.
VITE_API_URL=
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_FITNESS_RANGE=FITNESS!AB20:AY800
GOOGLE_SHEETS_SALON_RANGE=SALON!AB34:AY800
GOOGLE_SHEETS_AULA_RANGE=AULA!AB34:AY800
GOOGLE_SHEETS_ADMIN_MOVEMENTS_RANGE=ADMINISTRACIÓN!B12:AB3000
GOOGLE_SHEETS_ADMIN_BALANCES_RANGE=ADMINISTRACIÓN!AD12:AG14
AUTH_ENABLED=false
AUTH_USER=
AUTH_PASSWORD=
SESSION_SECRET=
PUBLIC_APP_URL=

# Operational endpoints. Keep disabled in production except during controlled diagnostics/import windows.
DEBUG_ENDPOINTS_ENABLED=false
IMPORT_ENDPOINTS_ENABLED=false
